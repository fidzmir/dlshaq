-- UNIVERSAL REQUEST FUNCTION (Works for Delta, Xeno, Buni, etc.)
local httpRequest = (syn and syn.request) or (http and http.request) or http_request or request

local function sendToDiscord(title, remoteName, dataString)
    local payload = {
        Url = WebhookURL,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = game:GetService("HttpService"):JSONEncode({
            ["embeds"] = {{
                ["title"] = title,
                ["color"] = 0xffa500, -- Orange for testing
                ["fields"] = {
                    { ["name"] = "Target", ["value"] = "```" .. remoteName .. "```" },
                    { ["name"] = "Data", ["value"] = "```lua\n" .. dataString .. "\n
```" }
                },
                ["footer"] = { ["text"] = "Timestamp: " .. os.date("%X") }
            }}
        })
    }

    local success, response = pcall(function()
        return httpRequest(payload)
    end)

    if not success then
        warn("❌ Logger Error: " .. tostring(response))
    else
        print("✅ Log Sent to Discord (Status: " .. tostring(response.StatusCode) .. ")")
    end
end

