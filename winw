-- [[ THE SEND FUNCTION ]]
local function post(name, msg)
    local payload = {
        Url = url,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = game:GetService("HttpService"):JSONEncode({
            ["content"] = "🚩 **Remote:** " .. name .. "\n**Data:** " .. tostring(msg)
        })
    }
    -- Run in background so it doesn't freeze your game
    task.spawn(function()
        requestFunc(payload)
    end)
end

