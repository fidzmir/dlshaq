local WebhookURL = "https://discord.com/api/webhooks/1489564311423815720/95RTxCNmEopgkqiRY1n_jH5hxMFuNqCS5OYxppId3UE_QxdJWgXuMPbVoubeVDhp-AT6"

local function sendToDiscord(remoteName, args)
    -- Formatting the arguments into a readable string
    local dataString = ""
    for i, v in pairs(args) do
        dataString = dataString .. "[" .. i .. "]: " .. tostring(v) .. "\n"
    end
    
    if dataString == "" then dataString = "No arguments sent." end

    -- The payload for Discord
    local payload = {
        Url = WebhookURL,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json"
        },
        Body = game:GetService("HttpService"):JSONEncode({
            ["embeds"] = {{
                ["title"] = "📡 Remote Intercepted",
                ["color"] = 0x2b2d31, -- Sleek dark grey
                ["fields"] = {
                    {
                        ["name"] = "Remote Object",
                        ["value"] = "```" .. remoteName .. "
```",
                        ["inline"] = true
                    },
                    {
                        ["name"] = "Data (Arguments)",
                        ["value"] = "```lua\n" .. dataString .. "\n```"
                    }
                },
                ["timestamp"] = DateTime.now():ToIsoDate()
            }}
        })
    }

    -- Using the executor's request function
    local success, response = pcall(function()
        return request(payload)
    end)

    if not success then
        warn("Failed to send to Discord: " .. tostring(response))
    end
end

-- Hooking logic
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if method == "FireServer" or method == "InvokeServer" then
        -- Send the data to your webhook asynchronously
        task.spawn(sendToDiscord, self.Name, args)
    end

    return oldNamecall(self, ...)
end)

