local function makeBtn(txt, pos, var)
    local b = Instance.new("TextButton", f); b.Size = UDim2.new(1, -10, 0, 40); b.Position = pos; b.Text = txt; b.BackgroundColor3 = Color3.new(0.6, 0, 0); b.TextColor3 = Color3.new(1,1,1)
    b.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        b.BackgroundColor3 = _G[var] and Color3.new(0, 0.6, 0) or Color3.new(0.6, 0, 0)
    end)
end

makeBtn("ATTACK ON/OFF", UDim2.new(0, 5, 0, 5), "AutoAttack")
makeBtn("WALK ON/OFF", UDim2.new(0, 5, 0, 50), "SafeWalk")
