-- I've swapped "discord.com" for "hooks.hyra.io" which is a standard proxy
local RawWebhook = "https://discord.com/api/webhooks/1489564311423815720/95RTxCNmEopgkqiRY1n_jH5hxMFuNqCS5OYxppId3UE_QxdJWgXuMPbVoubeVDhp-AT6"
local ProxyURL = RawWebhook:gsub("discord.com", "hooks.hyra.io")

local httpRequest = (request or http_request or (http and http.request) or (syn and syn.request))
local hookMethod = (hookmetamethod or (detour and detour.hook_metamethod))

local function sendToDiscord(title, remoteName, data)
    local payload = {
        Url = ProxyURL,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = game:GetService("HttpService"):JSONEncode({
            ["embeds"] = {{
                ["title"] = title,
                ["description"] = "Remote: `" .. tostring(remoteName) .. "`",
                ["color"] = 0x00ff00,
                ["fields"] = {
                    {["name"] = "Data", ["value"] = "```" .. tostring(data) .. "
```"}
                }
            }}
        })
    }
    
    -- Attempting the request
    task.spawn(function()
        local res = httpRequest(payload)
        if res then
            print("📡 Discord Response Code: " .. tostring(res.StatusCode))
        else
            warn("📡 No response from Proxy.")
        end
    end)
end

