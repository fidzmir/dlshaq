-- 2. THE HOOK
if hookMethod then
    local oldNamecall
    oldNamecall = hookMethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        if method == "FireServer" or method == "InvokeServer" then
            -- Log the first argument for simplicity
            local firstArg = tostring(args[1]) or "No Args"
            sendToDiscord("📡 Remote Intercepted", self.Name, firstArg)
        end

        return oldNamecall(self, ...)
    end)
    print("✅ Hook Applied.")
else
    warn("❌ Your executor does not support hooking.")
end
