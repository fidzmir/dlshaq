local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local PathfindingService = game:GetService("PathfindingService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local EventsFolder = ReplicatedStorage:WaitForChild("Events")

-- Config
_G.AutoAttack = false
_G.SafeWalk = false
_G.ESP = true
local ATTACK_RANGE = 200
local ATTACK_SPEED = 0.05 -- Adjusted for stability

-- 1. REMOTE HUNTER (Your Original Logic)
local function GetCurrentRemote()
    local bestRemote = nil
    local highestVersion = -1
    for _, v in pairs(EventsFolder:GetChildren()) do
        if v.Name:find("Attack") then
            local version = tonumber(v.Name:match("%d+")) or 0
            if version > highestVersion then
                highestVersion = version
                bestRemote = v
            end
        end
    end
    return bestRemote or EventsFolder:FindFirstChild("AttackV2") or EventsFolder:FindFirstChild("Attack")
end

-- 2. TARGET FILTER (Your Original Logic)
local function isValidEnemy(target)
    if target and target:FindFirstChild("Humanoid") and target.Humanoid.Health > 0 then
        if Players:GetPlayerFromCharacter(target) then return false end
        -- Filter out friendly NPCs
        if target:GetAttribute("IsNPC") == false or target.Name:lower():find("npc") then
            if not target:GetAttribute("MobLevel") then return false end
        end
        return true
    end
    return false
end

-- 3. GET NEAREST TARGET
local function GetNearest()
    local charFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Mobs") or workspace
    local closest, dist = nil, math.huge
    for _, e in pairs(charFolder:GetChildren()) do
        if isValidEnemy(e) and e:FindFirstChild("HumanoidRootPart") then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - e.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; closest = e end
        end
    end
    return closest
end

-- 4. SAFE WALKER (Anti-Ban)
local function WalkTo(pos)
    local path = PathfindingService:CreatePath({AgentCanJump = true})
    path:ComputeAsync(LocalPlayer.Character.HumanoidRootPart.Position, pos)
    if path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        for _, wp in ipairs(waypoints) do
            if not _G.SafeWalk then break end
            LocalPlayer.Character.Humanoid:MoveTo(wp.Position)
            if wp.Action == Enum.PathWaypointAction.Jump then LocalPlayer.Character.Humanoid.Jump = true end
            local reached = LocalPlayer.Character.Humanoid.MoveToFinished:Wait(0.5)
            if not reached then break end
        end
    end
end

-- 5. COMBINED MASTER LOOP
task.spawn(function()
    while task.wait(ATTACK_SPEED) do
        if _G.AutoAttack or _G.SafeWalk then
            local target = GetNearest()
            local remote = GetCurrentRemote()
            
            if target and target:FindFirstChild("HumanoidRootPart") then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - target.HumanoidRootPart.Position).Magnitude
                
                -- Attack Logic (Your Original Args)
                if _G.AutoAttack and remote and d <= ATTACK_RANGE then
                    remote:FireServer(5, 1, target)
                end
                
                -- Safe Walking (No Noclip)
                if _G.SafeWalk and d > 12 then
                    WalkTo(target.HumanoidRootPart.Position)
                end
            end
        end
    end
end)

-- 6. STEALTH GUI
local function CreateUI()
    local parent = CoreGui:FindFirstChild("RobloxGui") or LocalPlayer:WaitForChild("PlayerGui")
    if parent:FindFirstChild("DungeonMasterV7") then parent.DungeonMasterV7:Destroy() end

    local sg = Instance.new("ScreenGui", parent); sg.Name = "DungeonMasterV7"
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 160, 0, 110); main.Position = UDim2.new(0, 50, 0.5, 0); main.BackgroundColor3 = Color3.fromRGB(30, 30, 30); main.Active = true; main.Draggable = true

    local function btn(txt, pos, var)
        local b = Instance.new("TextButton", main)
        b.Size = UDim2.new(1, -10, 0, 45); b.Position = pos; b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(150, 0, 0); b.TextColor3 = Color3.new(1, 1, 1)
        b.MouseButton1Click:Connect(function()
            _G[var] = not _G[var]
            b.BackgroundColor3 = _G[var] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
        end)
    end

    btn("AUTO ATTACK", UDim2.new(0, 5, 0, 5), "AutoAttack")
    btn("SAFE FARM", UDim2.new(0, 5, 0, 55), "SafeWalk")
end

CreateUI()
