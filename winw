local WH = "https://hooks.hyra.io/api/webhooks/1489564311423815720/95RTxCNmEopgkqiRY1n_jH5hxMFuNqCS5OYxppId3UE_QxdJWgXuMPbVoubeVDhp-AT6"
local http = (request or http_request or (http and http.request))
local RS = game:GetService("ReplicatedStorage")

local function send(title, msg)
    task.spawn(function()
        http({
            Url = WH,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["embeds"] = {{
                    ["title"] = title,
                    ["description"] = "```" .. tostring(msg) .. "
```",
                    ["color"] = 0x00FF00
                }}
            })
        })
    end)
end

-- 1. Scan everything currently in ReplicatedStorage
print("--- Scanning ReplicatedStorage ---")
for _, v in pairs(RS:GetDescendants()) do
    if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
        print("Found: " .. v.Name)
        send("Found Remote", v:GetFullName())
    end
end

-- 2. Hook to catch them when they are actually used
local old
old = hookmetamethod(game, "__namecall", function(self, ...)
    local m = getnamecallmethod()
    if not checkcaller() and (m == "FireServer" or m == "InvokeServer") then
        -- Check if this remote is inside ReplicatedStorage
        if self:IsDescendantOf(RS) then
            send("Captured Fire: " .. self.Name, tostring((...)))
        end
    end
    return old(self, ...)
end)

print("--- Scan & Hook Complete ---")
