-- [[ HELPER: FORMAT DATA FOR DISCORD ]]
local function formatArgs(args)
    local result = ""
    for i, v in pairs(args) do
        local valType = typeof(v)
        local displayVal = tostring(v)
        
        if valType == "Instance" then
            displayVal = v:GetFullName()
        elseif valType == "table" then
            displayVal = "{...} (Table)"
        end
        
        result = result .. "[" .. i .. "] (" .. valType .. "): " .. displayVal .. "\n"
    end
    return result ~= "" and result or "No arguments"
end

-- [[ DISCORD SENDER ]]
local function sendToDiscord(remoteName, remoteType, args)
    local dataString = formatArgs(args)
    
    local payload = {
        Url = WebhookURL,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = game:GetService("HttpService"):JSONEncode({
            ["username"] = "Map Data Dump Bot",
            ["embeds"] = {{
                ["title"] = "🛰️ Remote Intercepted",
                ["description"] = "Captured communication between Client and Server.",
                ["color"] = 0x5865F2, -- Discord Blurple
                ["fields"] = {
                    { ["name"] = "Remote Name", ["value"] = "```" .. remoteName .. "```", ["inline"] = true },
                    { ["name"] = "Type", ["value"] = "```" .. remoteType .. "```", ["inline"] = true },
                    { ["name"] = "Arguments Sent", ["value"] = "```lua\n" .. dataString .. "\n
```" }
                },
                ["footer"] = { ["text"] = "School Project • " .. os.date("%X") }
            }}
        })
    }

    task.spawn(function()
        local success, err = pcall(function()
            return httpRequest(payload)
        end)
        if not success then warn("Discord Log Fail: " .. tostring(err)) end
    end)
end

-- [[ THE MAIN HOOK ]]
local oldNamecall
oldNamecall = hookMethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if method == "FireServer" or method == "InvokeServer" then
        -- Send data to Discord without lagging the game
        sendToDiscord(self.Name, method, args)
    end

    return oldNamecall(self, ...)
end)

