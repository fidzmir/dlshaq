local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local PathfindingService = game:GetService("PathfindingService")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local EventsFolder = ReplicatedStorage:WaitForChild("Events")

_G.AutoAttack = false
_G.SafeWalk = false

-- 1. STABLE REMOTE HUNTER
local function GetAttackRemote()
    local best = nil
    local high = -1
    for _, v in pairs(EventsFolder:GetChildren()) do
        if v.Name:find("Attack") then
            local n = tonumber(v.Name:match("%d+")) or 0
            if n > high then high = n; best = v end
        end
    end
    return best or EventsFolder:FindFirstChild("Attack")
end

-- 2. IMPROVED TARGET FINDER
local function GetNearestEnemy()
    local charFolder = workspace:FindFirstChild("Characters") or workspace:FindFirstChild("Mobs") or workspace
    local closest, dist = nil, math.huge
    for _, e in pairs(charFolder:GetChildren()) do
        if e:FindFirstChild("Humanoid") and e.Humanoid.Health > 0 and not Players:GetPlayerFromCharacter(e) then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - e.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; closest = e end
        end
    end
    return closest
end

-- 3. ATTACK THREAD (Isolated from Movement)
task.spawn(function()
    while true do
        if _G.AutoAttack then
            local target = GetNearestEnemy()
            local remote = GetAttackRemote()
            
            if target and remote then
                -- This tries your original method PLUS the modern method
                pcall(function()
                    -- Your original:
                    remote:FireServer(5, 1, target) 
                    -- Modern fallback (common in new dungeon games):
                    remote:FireServer(target) 
                    -- HRP fallback:
                    if target:FindFirstChild("HumanoidRootPart") then
                        remote:FireServer(target.HumanoidRootPart)
                    end
                end)
            end
        end
        task.wait(0.015) -- High speed attack
    end
end)

-- 4. MOVEMENT THREAD (Independent)
task.spawn(function()
    while true do
        if _G.SafeWalk then
            local target = GetNearestEnemy()
            if target and target:FindFirstChild("HumanoidRootPart") then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - target.HumanoidRootPart.Position).Magnitude
                if d > 10 then
                    -- Simple MoveTo for better responsiveness
                    LocalPlayer.Character.Humanoid:MoveTo(target.HumanoidRootPart.Position)
                end
            end
        end
        task.wait(0.2)
    end
end)

