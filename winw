-- [[ THE HOOK ]]
local old
old = hook(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
        -- We only log the FIRST argument to keep it simple and avoid errors
        local data = args[1]
        post(tostring(self.Name), tostring(data))
    end

    return old(self, ...)
end)

