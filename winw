-- 🎣 THE HOOK
local oldNamecall
oldNamecall = hookMethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if method == "FireServer" or method == "InvokeServer" then
        -- Convert arguments to string safely
        local success, dataStr = pcall(function()
            local str = ""
            for i, v in pairs(args) do
                str = str .. "[" .. i .. "]: " .. tostring(v) .. "\n"
            end
            return str ~= "" and str or "No Arguments"
        end)
        
        task.spawn(sendToDiscord, "📡 Remote Fired", self.Name, dataStr or "Error reading args")
    end

    return oldNamecall(self, ...)
end)

