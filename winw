-- Services
local PathfindingService = game:GetService("PathfindingService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

-- Variables
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

-- Configuration
_G.AutoFarmActive = false
_G.AutoAttackActive = false
local ATTACK_RANGE = 15 -- Studs

-- 1. Navigation Logic (The "Anti-Noclip" Walker)
local function MoveToTarget(targetPosition)
    local path = PathfindingService:CreatePath({
        AgentRadius = 3,      -- Keeps you from scraping against walls
        AgentHeight = 5,
        AgentCanJump = true,  -- Will jump over small crates/obstacles
        WaypointSpacing = 4   -- Smoothness of the walk
    })

    local success, errorMessage = pcall(function()
        path:ComputeAsync(RootPart.Position, targetPosition)
    end)

    if success and path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        for _, waypoint in ipairs(waypoints) do
            if not _G.AutoFarmActive then break end

            -- Handle Obstacles (Jumping)
            if waypoint.Action == Enum.PathWaypointAction.Jump then
                Humanoid.Jump = true
            end

            Humanoid:MoveTo(waypoint.Position)
            
            -- Wait until we reach the waypoint or time out (prevents getting stuck)
            local timedOut = not Humanoid.MoveToFinished:Wait(1)
            if timedOut then
                Humanoid.Jump = true -- Try to jump if stuck
                break 
            end

            -- Safety check: If target moved too far, recalculate path
            if (waypoints[#waypoints].Position - targetPosition).Magnitude > 10 then
                break
            end
        end
    end
end

-- 2. Find Nearest Enemy
local function GetTarget()
    local closestMob = nil
    local shortestDist = math.huge
    local potentialTargets = workspace:FindFirstChild("Mobs") or workspace:FindFirstChild("Enemies") or workspace

    for _, v in pairs(potentialTargets:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            local dist = (RootPart.Position - v.HumanoidRootPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closestMob = v
            end
        end
    end
    return closestMob
end

-- 3. Main Master Loop
task.spawn(function()
    while true do
        if _G.AutoFarmActive then
            local target = GetTarget()
            if target and target:FindFirstChild("HumanoidRootPart") then
                local dist = (RootPart.Position - target.HumanoidRootPart.Position).Magnitude
                
                -- Attack if close
                if dist <= ATTACK_RANGE and _G.AutoAttackActive then
                    local remote = game:GetService("ReplicatedStorage").Events:FindFirstChild("Attack")
                    if remote then remote:FireServer(1, target) end
                end

                -- Walk if far (Pathfinding)
                if dist > 8 then
                    MoveToTarget(target.HumanoidRootPart.Position)
                end
            end
        end
        task.wait(0.2)
    end
end)

-- 4. Minimalist Stealth UI
local function CreateUI()
    local sg = Instance.new("ScreenGui", CoreGui:FindFirstChild("RobloxGui") or LocalPlayer.PlayerGui)
    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 140, 0, 90)
    frame.Position = UDim2.new(0, 10, 0.5, 0)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.Active = true
    frame.Draggable = true

    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.Position = UDim2.new(0, 5, 0, 5)
    btn.Text = "FARM: OFF"
    btn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)

    btn.MouseButton1Click:Connect(function()
        _G.AutoFarmActive = not _G.AutoFarmActive
        _G.AutoAttackActive = _G.AutoFarmActive
        btn.Text = _G.AutoFarmActive and "FARM: ON" or "FARM: OFF"
        btn.BackgroundColor3 = _G.AutoFarmActive and Color3.fromRGB(50, 180, 50) or Color3.fromRGB(180, 50, 50)
    end)
    
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Position = UDim2.new(0, 0, 0, 50)
    label.Text = "Status: Monitoring..."
    label.TextColor3 = Color3.new(0.7, 0.7, 0.7)
    label.BackgroundTransparency = 1
end

CreateUI()
