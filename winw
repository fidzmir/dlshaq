-- 🔍 1. FINDING THE REQUEST FUNCTION
-- We check every possible name an executor might use
local httpRequest = (request or http_request or (http and http.request) or (syn and syn.request))

-- 🔍 2. FINDING THE HOOK FUNCTION
local hookMethod = (hookmetamethod or (detour and detour.hook_metamethod))

-- 🛡️ SAFETY CHECK: If the executor is missing features, tell the console
if not httpRequest then 
    warn("❌ Error: Your executor does not support HTTP Requests.") 
    return 
end
if not hookMethod then 
    warn("❌ Error: Your executor does not support HookMetaMethod.") 
    return 
end

local function sendToDiscord(title, remoteName, dataString)
    local payload = {
        Url = WebhookURL,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = game:GetService("HttpService"):JSONEncode({
            ["embeds"] = {{
                ["title"] = title,
                ["color"] = 0x00ff00, -- Green for success
                ["fields"] = {
                    { ["name"] = "Remote", ["value"] = "```" .. tostring(remoteName) .. "
```" },
                    { ["name"] = "Data", ["value"] = "```lua\n" .. tostring(dataString) .. "\n```" }
                },
                ["footer"] = { ["text"] = "School Project Test • " .. os.date("%X") }
            }}
        })
    }

    -- Wrap in pcall so it doesn't crash the game if Discord is slow
    pcall(function()
        httpRequest(payload)
    end)
end

