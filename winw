        local dataStr = ""
        for i, v in pairs(args) do
            dataStr = dataStr .. "[" .. i .. "]: " .. tostring(v) .. "\n"
        end
        
        -- Send data to Discord
        task.spawn(sendToDiscord, "📡 Remote Fired", self.Name, dataStr)
    end

    return oldNamecall(self, ...)
end)

