local function sendToDiscord(remoteName, args)
    local dataString = ""
    for i, v in pairs(args) do
        dataString = dataString .. "[" .. tostring(i) .. "]: " .. tostring(v) .. "\n"
    end

    local payload = {
        Url = WebhookURL,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = game:GetService("HttpService"):JSONEncode({
            ["content"] = "🛰️ **Remote Intercepted!**\n**Remote:** `" .. tostring(remoteName) .. "`\n**Args:**\n```lua\n" .. dataString .. "
```"
        })
    }
    
    local success, err = pcall(function()
        httpRequest(payload)
    end)
    
    if success then 
        print("📤 Data sent to Discord!") 
    else 
        warn("📤 Failed to send: " .. tostring(err)) 
    end
end

